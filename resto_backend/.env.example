# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/resto_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Booking Fee (per guest in USD)
BOOKING_FEE_PER_GUEST=1

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
